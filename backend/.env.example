# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL) - bắt buộc chạy PostgreSQL và tạo DB trước khi start app
# Docker (từ root repo): docker compose up -d — xem README.md mục Database
# Hoặc cài local: 1) PostgreSQL port 5432  2) createdb -U postgres health_assistant
# 3) psql -U postgres -d health_assistant -f database/schema.sql
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=health_assistant
DB_LOGGING=false

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth (Web application)
# Console: Authorized redirect URI phải trỏ về GOOGLE_CALLBACK_URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev (khuyến nghị): callback đi qua frontend proxy để cookie set cho :3001
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Cloudinary (lưu ảnh)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Folder mặc định cho avatar
CLOUDINARY_AVATAR_FOLDER=health-assistant/avatars

# CORS - URL frontend
FRONTEND_URL=http://localhost:3001

# URL công khai của API (dùng ghép MOMO_IPN nếu không set MOMO_IPN_URL đầy đủ)
API_PUBLIC_BASE_URL=http://localhost:4000

# MoMo (Partner) — để trống = chế độ dev: link thanh toán giả + vẫn gửi mail QR
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_CREATE_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:3001/patient/bookings
MOMO_IPN_URL=
MOMO_PARTNER_NAME=ClinicalPrecision
MOMO_STORE_ID=ClinicalPrecisionStore

# SMTP gửi email (để trống = chỉ log, không gửi thật)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@localhost

# OTP xác thực email cho bệnh nhân đăng ký mới
PATIENT_VERIFY_CODE_EXPIRES_MINUTES=10

# LiveKit (livestream bác sĩ — để trống = API join trả 503 và hướng dẫn cấu hình)
# Cloud: Project Settings → URL dạng wss://xxx.livekit.cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
