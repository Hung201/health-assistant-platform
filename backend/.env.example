# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL) - bắt buộc chạy PostgreSQL và tạo DB trước khi start app
# 1. Cài PostgreSQL, start service (port 5432)
# 2. Tạo DB: createdb -U postgres health_assistant
# 3. Chạy schema: psql -U postgres -d health_assistant -f database/schema.sql
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=health_assistant
DB_LOGGING=false

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS - URL frontend
FRONTEND_URL=http://localhost:3001
